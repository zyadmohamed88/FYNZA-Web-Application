# انسخ هذا الملف إلى .env بجانب app.py ثم عدّل القيم.
#
# إرسال الرمز عبر Gmail — أنشئ "App Password" من حساب Google:
# https://support.google.com/accounts/answer/185833
# (يمكنك ترك المسافات في SMTP_PASSWORD — البرنامج يزيلها تلقائياً)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=zyadelking73@gmail.com
SMTP_PASSWORD=oult gdfr hrgw fisg
SMTP_FROM=FYNZA <zyadelking73@gmail.com>

# إذا منفذ 587 محظور على الشبكة، جرّب SSL على 465:
# SMTP_SSL=true
# SMTP_PORT=465

# للتجربة بدون بريد: اترك SMTP_PASSWORD فارغاً وفعّل السطر التالي (لا تستخدمه على الإنترنت)
# DEV_RETURN_OTP=true

# بريد Google Workspace للشركة (نطاقات مفصولة بفاصلة)، اختياري:
# GOOGLE_WORKSPACE_ALLOWED_DOMAINS=mycompany.com

# لتعطيل شرط Gmail في التطوير فقط (لا تستخدمه في الإنتاج):
# ALLOW_NON_GMAIL_EMAILS=true
